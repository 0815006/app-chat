# === 所有环境共享的默认值（.env 基线）===
# 各模式的 .env.[mode] 文件仅需写差异项，同名变量自动覆盖

# Supabase 连接（所有环境统一）
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# 后端类型：GO
VITE_BACKEND_TYPE=GO

# Go 后端地址 — 默认留空（同源自适应 / window.location 推导）
# .env.production  覆盖为腾讯云域名
# .env.lan         覆盖为内网服务器 IP
VITE_GO_BASE_URL=
VITE_GO_WS_URL=
